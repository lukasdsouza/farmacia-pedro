# ============================================================
# OPCAO 1: Groq (GRATIS, recomendado)
# 1. Acesse https://console.groq.com
# 2. Crie uma conta gratuita
# 3. Va em "API Keys" e gere uma chave
# 4. Cole abaixo:
# ============================================================
GROQ_API_KEY=gsk_COLE_SUA_CHAVE_AQUI

# Modelo padrao da Groq (pode mudar se quiser):
# CHAT_MODEL=llama-3.3-70b-versatile

# ============================================================
# OPCAO 2: Ollama (100% local, sem internet)
# 1. Instale: https://ollama.com
# 2. Baixe um modelo: ollama pull llama3.2
# 3. Suba o servidor: ollama serve
# ============================================================
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://localhost:11434/v1
# CHAT_MODEL=llama3.2

# ============================================================
# OPCAO 3: Claude Anthropic (pago, melhor qualidade)
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================================
# OPCAO 4: Simulacao local (sem IA, gratuito, limitado)
# ============================================================
# CHAT_AI_MODE=simulate

# ============================================================
# Configuracoes da farmacia
# ============================================================
# CHAT_LOJA_NOME=Drogarias Max - Barra Blue
# CHAT_ENDERECO=Av. das Americas, 12.700
# CHAT_DELIVERY_RULES=Barra:8.00:45 min;Recreio:10.00:60 min;Jacarepagua:12.00:60 min

# Banco de dados (padrao ja funciona)
# ERP_DB_PATH=data/erp_demo.db
