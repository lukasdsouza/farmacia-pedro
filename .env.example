# Configuracao demo
ERP_DB_PATH=data/erp_demo.db
REPORT_DIR=out

# Regras de negocio
BONUS_MARKUP_PCT=110
DAYS_NO_SALES=60
LOW_MARGIN_THRESHOLD=0.15
SAFETY_STOCK_DAYS=15
TURNOVER_WINDOW_DAYS=30

# Controle de acesso (escopos separados por virgula)
OPERATIONAL_SCOPES=stock,orders
AUDIT_SCOPES=invoices,costs
STRATEGIST_SCOPES=sales,competitors
INVENTORY_SCOPES=stock,turnover

# Automacao em Python (substitui n8n/Make)
# AUTOMATION_MODE=once | schedule | unico | agendado
AUTOMATION_MODE=unico
AUTOMATION_INTERVAL_MIN=30
AUTOMATION_MAX_RUNS=0
AUTOMATION_RETRIES=1
AUTOMATION_RETRY_DELAY_SEC=5
AUTOMATION_SEED_DEMO=1

# Entrega via WhatsApp (webhook stub)
WHATSAPP_WEBHOOK_URL=
WHATSAPP_TO=
WHATSAPP_SENDER=

# Chat pseudo-IA
CHAT_MODE=atendimento
CHAT_LOJA_NOME=Drogarias Max - Barra Blue
CHAT_ENDERECO=Av. das Americas, 12.700
CHAT_FILIAL=Barra Blue
CHAT_RESERVA_VALIDADE=fim do dia
CHAT_DELIVERY_RULES=Recreio:8:60min;Barra:5:30min
CHAT_DELIVERY_FALLBACK=vou consultar a taxa certinha e ja te retorno.
CHAT_WEBHOOK_HOST=0.0.0.0
CHAT_WEBHOOK_PORT=8000
CHAT_SESSION_DIR=out/chat_sessions
CHAT_SESSION_ID=atendimento
LOW_STOCK_THRESHOLD=10

# Integracao com sistema existente (porta aberta)
# INTEGRATION_ADAPTER=local | webhook
INTEGRATION_ADAPTER=local
INTEGRATION_ADAPTER_PATH=
INTEGRATION_WEBHOOK_URL=
